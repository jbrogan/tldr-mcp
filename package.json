{
  "name": "tldr-mcp",
  "version": "0.1.0",
  "description": "MCP server for tldr app",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tldr-mcp": "./dist/index.js",
    "tldr-mcp-cli": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "cli": "node dist/cli.js",
    "dev": "tsc --watch",
    "start:http": "node dist/server.js",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@supabase/supabase-js": "^2.99.0",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.25.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.0",
    "agents": "^0.11.6",
    "typescript": "^5.9.3",
    "wrangler": "^4.85.0"
  }
}
