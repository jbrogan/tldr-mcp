# LLM provider for natural language commands: anthropic | openai (default: anthropic)
LLM_PROVIDER=anthropic

# API keys - set the one for your chosen provider
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: override default model (e.g. claude-3-5-sonnet, gpt-4o)
LLM_MODEL=

# ============================================================================
# Supabase Configuration
# ============================================================================

# Supabase project URL (required for multi-user mode)
SUPABASE_URL=https://pibazihemywzjcwjwicm.supabase.co

# Supabase anon key - public key for client-side operations (required)
SUPABASE_ANON_KEY=sb_publishable_oOGYwGUBZYdzSh5MNJQgrQ_NksybKUL

# Supabase service role key - admin key that bypasses RLS (optional, for admin operations)
SUPABASE_SERVICE_ROLE_KEY=

# Development user ID - use this to bypass auth during local development
# Set to a valid user UUID from your Supabase profiles table
TLDR_DEV_USER_ID=653fe245-fff2-4039-8f30-c0da013babde
